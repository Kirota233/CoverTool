{
  "name": "covertool",
  "version": "2.0.0",
  "description": "多功能封面与视频处理工具",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac"
  },
  "author": "Taiki",
  "license": "ISC",
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  },

  "build": {
    "appId": "com.taiki.covertool",
    "productName": "多功能封面工具",

    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.utilities",

      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },

    "directories": {
      "output": "dist",
      "buildResources": "build"
    },

    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*"
    ],

    "files": [
      "main.js",
      "renderer.js",
      "renderer-embed.js",
      "renderer-remove.js",
      "index.html",
      "embed.html",
      "remove-frames.html",
      "launcher.html",
      "info.html",
      "package.json",
      "node_modules/",
      "fonts/"
    ]
  },

  "publish": {
    "provider": "github",
    "owner": "Kirota233",
    "repo": "CoverTool"
  }
}