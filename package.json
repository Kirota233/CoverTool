{
  "name": "covertool",
  "version": "1.0.0",
  "description": "自动化封面与视频合成工具",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac"
  },
  "author": "Taiki",
  "license": "ISC",
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.taiki.covertool",
    "productName": "自动化封面合成器",
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.png"
    },
    "directories": {
      "output": "dist"
    },
    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*"
    ]
  }
}